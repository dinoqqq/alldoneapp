{
    "indexes": [
        {
            "__comment__": "OKRs - Scheduled renewal of expired active OKRs",
            "collectionGroup": "projectOkrs",
            "queryScope": "COLLECTION_GROUP",
            "fields": [
                {
                    "fieldPath": "objectType",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "status",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "periodEnd",
                    "order": "ASCENDING"
                }
            ]
        },
        {
            "__comment__": "Tasks - Template tasks query",
            "collectionGroup": "items",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "calendarData",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "gmailData",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "dueDate",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "sortIndex",
                    "order": "DESCENDING"
                }
            ]
        },
        {
            "__comment__": "Tasks - Done tasks with completion date",
            "collectionGroup": "items",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "inDone",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "completed",
                    "order": "DESCENDING"
                },
                {
                    "fieldPath": "sortIndex",
                    "order": "DESCENDING"
                }
            ]
        },
        {
            "__comment__": "Tasks - Open tasks (not done, not subtask)",
            "collectionGroup": "items",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "inDone",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "isSubtask",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "sortIndex",
                    "order": "DESCENDING"
                }
            ]
        },
        {
            "__comment__": "Tasks - Subtasks query",
            "collectionGroup": "items",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "parentId",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "isSubtask",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "sortIndex",
                    "order": "DESCENDING"
                }
            ]
        },
        {
            "__comment__": "Tasks - Calendar tasks within time range",
            "collectionGroup": "items",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "inDone",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "sortIndex",
                    "order": "ASCENDING"
                }
            ]
        },
        {
            "__comment__": "Tasks - Assistant visible open tasks due today or overdue",
            "collectionGroup": "tasks",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "isPublicFor",
                    "arrayConfig": "CONTAINS"
                },
                {
                    "fieldPath": "currentReviewerId",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "inDone",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "isSubtask",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "sortIndex",
                    "order": "DESCENDING"
                },
                {
                    "fieldPath": "dueDate",
                    "order": "DESCENDING"
                }
            ]
        },
        {
            "__comment__": "Tasks - Assistant visible completed tasks by completion date",
            "collectionGroup": "tasks",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "isPublicFor",
                    "arrayConfig": "CONTAINS"
                },
                {
                    "fieldPath": "done",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "inDone",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "isSubtask",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "completed",
                    "order": "DESCENDING"
                },
                {
                    "fieldPath": "sortIndex",
                    "order": "DESCENDING"
                }
            ]
        },
        {
            "__comment__": "Milestones - Undone milestones by date",
            "collectionGroup": "milestonesItems",
            "queryScope": "COLLECTION",
            "fields": [
                {
                    "fieldPath": "done",
                    "order": "ASCENDING"
                },
                {
                    "fieldPath": "date",
                    "order": "ASCENDING"
                }
            ]
        },
        {
