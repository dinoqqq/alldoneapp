rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function publicForAll() {
      return 0;
    }

    function privateProject() {
      return 2;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function userHasProjectIn(uid, fieldName, projectId) {
      return userDoc(uid).data[fieldName] is list && projectId in userDoc(uid).data[fieldName];
    }

    function isProjectMember(projectId) {
      return signedIn() && (
        userHasProjectIn(request.auth.uid, 'projectIds', projectId) ||
        userHasProjectIn(request.auth.uid, 'guideProjectIds', projectId) ||
        userHasProjectIn(request.auth.uid, 'templateProjectIds', projectId) ||
        userHasProjectIn(request.auth.uid, 'archivedProjectIds', projectId)
      );
    }

    function isPublicSharedProject(projectId) {
      return projectDoc(projectId).data.isShared != privateProject();
    }

    function isObjectPublic(data) {
      return data.isPublicFor is list && publicForAll() in data.isPublicFor;
    }

    function canReadObject(projectId, data) {
      return isProjectMember(projectId) && (
        isObjectPublic(data) ||
        (data.isPublicFor is list && request.auth.uid in data.isPublicFor)
      );
    }

    function canReadSharedObject(projectId, data) {
      return isPublicSharedProject(projectId) && isObjectPublic(data);
    }

    function canReadProject(projectId) {
      return isProjectMember(projectId) || isPublicSharedProject(projectId);
    }

    function canWriteObject(projectId, data) {
      return isProjectMember(projectId) && (
        isObjectPublic(data) ||
        (data.isPublicFor is list && request.auth.uid in data.isPublicFor)
      );
    }

    function canReadUserScopedProjectData(projectId, userId) {
      return signedIn() && request.auth.uid == userId && isProjectMember(projectId);
    }

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId ||
        (
          resource.data.projectIds is list &&
          userDoc(request.auth.uid).data.projectIds is list &&
          resource.data.projectIds.hasAny(userDoc(request.auth.uid).data.projectIds)
        )
      );
      allow create: if signedIn() && request.auth.uid == userId;
      allow update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow read: if canReadProject(projectId);
      allow create: if signedIn() && request.auth.uid in request.resource.data.userIds;
      allow update, delete: if isProjectMember(projectId);
    }

    match /items/{projectId}/tasks/{taskId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow create: if canWriteObject(projectId, request.resource.data);
      allow update: if canReadObject(projectId, resource.data) && canWriteObject(projectId, request.resource.data);
      allow delete: if canReadObject(projectId, resource.data);
    }

    match /noteItems/{projectId}/notes/{noteId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow create: if canWriteObject(projectId, request.resource.data);
      allow update: if canReadObject(projectId, resource.data) && canWriteObject(projectId, request.resource.data);
      allow delete: if canReadObject(projectId, resource.data);
    }

    match /noteItemsVersions/{projectId}/{noteId}/{versionId} {
      allow read, write: if canReadObject(projectId, get(/databases/$(database)/documents/noteItems/$(projectId)/notes/$(noteId)).data);
    }

    match /noteItemsDailyVersions/{projectId}/notes/{noteId} {
      allow read, write: if canReadObject(projectId, get(/databases/$(database)/documents/noteItems/$(projectId)/notes/$(noteId)).data);
    }

    match /goals/{projectId}/items/{goalId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow create: if canWriteObject(projectId, request.resource.data);
      allow update: if canReadObject(projectId, resource.data) && canWriteObject(projectId, request.resource.data);
      allow delete: if canReadObject(projectId, resource.data);
    }

    match /chatObjects/{projectId}/chats/{chatId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow create: if canWriteObject(projectId, request.resource.data);
      allow update: if canReadObject(projectId, resource.data) && canWriteObject(projectId, request.resource.data);
      allow delete: if canReadObject(projectId, resource.data);
    }

    match /projectsContacts/{projectId}/contacts/{contactId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow create: if canWriteObject(projectId, request.resource.data);
      allow update: if canReadObject(projectId, resource.data) && canWriteObject(projectId, request.resource.data);
      allow delete: if canReadObject(projectId, resource.data);
    }

    match /skills/{projectId}/items/{skillId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow create: if canWriteObject(projectId, request.resource.data);
      allow update: if canReadObject(projectId, resource.data) && canWriteObject(projectId, request.resource.data);
      allow delete: if canReadObject(projectId, resource.data);
    }

    match /assistants/{projectId}/items/{assistantId} {
      allow read: if projectId == 'globalProject' || canReadProject(projectId);
      allow write: if isProjectMember(projectId);
    }

    // Per-assistant MCP server secrets (bearer tokens / OAuth tokens). Server-only:
    // written + read exclusively by Cloud Functions via the Admin SDK (which bypasses
    // rules). Never exposed to clients — the non-secret config (label, url, tokenLast4)
    // lives on the assistant doc above.
    match /assistants/{projectId}/mcpSecrets/{secretId} {
      allow read, write: if false;
    }

    // Server-managed heartbeat dispatch registry. It contains internal timing
    // and execution state and must never be client-readable or client-writable.
    match /assistantHeartbeatSchedules/{scheduleId} {
      allow read, write: if false;
    }

    function isAdministrator() {
      return signedIn() && get(/databases/$(database)/documents/roles/administrator).data.userId == request.auth.uid;
    }

    match /assistantSkills/{projectId}/items/{skillId} {
      allow read: if signedIn();
      allow write: if isAdministrator();
    }

    match /assistantSkillImports/{importId} {
      allow read, write: if isAdministrator();
    }

    match /assistantSkillImportJobs/{jobId} {
      allow read: if isAdministrator();
      allow write: if false;
    }

    match /assistantTasks/{projectId}/{assistantId}/{taskId} {
      allow read, write: if projectId == 'globalProject' || isProjectMember(projectId);
    }

    match /assistantTasks/{projectId}/preConfigTasks/{taskId} {
      allow read, write: if projectId == 'globalProject' || isProjectMember(projectId);
    }

    match /projectHappiness/{projectId}/users/{userId}/days/{dayId} {
      allow read, write: if canReadUserScopedProjectData(projectId, userId);
    }

    match /statistics/{projectId}/{userId}/{dayId} {
      allow read: if isProjectMember(projectId);
      allow write: if canReadUserScopedProjectData(projectId, userId);
    }

    // Aggregated gold earn/spend rollups (daily/monthly). Computed server-side by
    // the aggregateGoldTransactionStats trigger; only administrators may read them.
    match /goldStats/{document=**} {
      allow read: if isAdministrator();
      allow write: if false;
    }

    match /chatComments/{projectId}/{chatType}/{objectId}/comments/{commentId} {
      allow read: if canReadProject(projectId);
      // A member may only create a comment authored as themselves: if creatorId is set it must
      // equal the caller's uid. This blocks forging a comment as another user (impersonation /
      // confused-deputy). Assistant/system comments are written server-side (admin SDK) and bypass
      // rules, so they are unaffected.
      allow create: if isProjectMember(projectId)
        && (!('creatorId' in request.resource.data) || request.resource.data.creatorId == request.auth.uid);
      allow update, delete: if isProjectMember(projectId) && signedIn();
    }

    match /projectsFeeds/{projectId}/{dateId}/{feedId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow write: if isProjectMember(projectId);
    }

    match /projectsInnerFeeds/{projectId}/{objectType}/{objectId}/feeds/{feedId} {
      allow read: if canReadObject(projectId, resource.data) || canReadSharedObject(projectId, resource.data);
      allow write: if isProjectMember(projectId);
    }

    match /feedsStore/{projectId}/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId && isProjectMember(projectId);
    }

    match /feedsCount/{projectId}/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId && isProjectMember(projectId);
    }

    match /chatNotifications/{projectId}/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId && isProjectMember(projectId);
    }

    match /notifications/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /karmaPoints/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /payments/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /subscriptions/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /invoiceData/{projectId}/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId && isProjectMember(projectId);
    }

    match /userForceReloads/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /emailNotifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userIds is list && request.auth.uid in resource.data.userIds;
      allow create: if signedIn() && request.resource.data.userIds is list && request.auth.uid in request.resource.data.userIds;
    }

    match /pushNotifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userIds is list && request.auth.uid in resource.data.userIds;
      allow create: if signedIn() && request.resource.data.userIds is list && request.auth.uid in request.resource.data.userIds;
    }

    match /followers/{projectId}/{objectType}/{objectId} {
      allow read, write: if isProjectMember(projectId);
    }

    match /usersFollowing/{projectId}/entries/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId && isProjectMember(projectId);
    }

    match /workstreams/{projectId}/items/{workstreamId} {
      allow read: if isProjectMember(projectId);
      allow write: if isProjectMember(projectId);
    }

    match /projectsInvitation/{projectId}/invitations/{invitationId} {
      allow read, write: if isProjectMember(projectId);
    }

    match /events/{projectId}/rooms/{roomId} {
      allow read, write: if isProjectMember(projectId);
    }

    match /skillsDefaultPrivacy/{projectId}/items/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId && isProjectMember(projectId);
    }

    match /tagsColors/{projectId}/{document=**} {
      allow read, write: if isProjectMember(projectId);
    }

    match /stickyNotesData/{noteId} {
      allow read, write: if signedIn();
    }

    match /runtimeErrors/{errorId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    match /info/{document=**} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /roles/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
